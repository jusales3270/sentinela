# StrixGuard Backend Environment Configuration

# Application
APP_NAME=StrixGuard
DEBUG=true
MOCK_MODE=true
SECRET_KEY=strixguard-local-development-secret-key-12345

# Database
DATABASE_URL=sqlite:///./data/strixguard.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic/claude-sonnet-4
LLM_API_KEY=

# Strix CLI
STRIX_PATH=strix
