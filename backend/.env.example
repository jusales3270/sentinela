# StrixGuard Backend Environment Configuration

# Application
APP_NAME=StrixGuard
DEBUG=false
MOCK_MODE=true
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Database
DATABASE_URL=sqlite:///./strixguard.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic/claude-sonnet-4
LLM_API_KEY=your-llm-api-key-here

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@strixguard.local

# Strix CLI
STRIX_PATH=strix
